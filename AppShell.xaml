<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Parcial13_GaleriaMusical.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Parcial13_GaleriaMusical"
    Title="Parcial13_GaleriaMusical"
    FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="120" BackgroundColor="{StaticResource Primary}">
            <Label Text="🎵 Galería Musical" 
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>
    </Shell.FlyoutHeader>

    <MenuItem Text="🏠 Inicio" IconImageSource="home.png" Command="{Binding GoToMainCommand}"/>
    <MenuItem Text="🎵 Player" IconImageSource="music.png" Command="{Binding GoToPlayerCommand}"/>
    <MenuItem Text="🌙 Theme" IconImageSource="theme.png" Command="{Binding ToggleThemeCommand}"/>

    <ShellContent Title="Inicio" 
                  Icon="home.png"
                  ContentTemplate="{DataTemplate local:MainPage}" />

    <ShellContent Title="Player" 
                  Icon="music.png"
                  ContentTemplate="{DataTemplate local:PlayerPage}" 
                  Route="PlayerPage"/>

</Shell>
